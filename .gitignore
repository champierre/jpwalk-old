# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your text editor
# or operating system, you probably want to add a global ignore instead:
#   git config --global core.excludesfile '~/.gitignore_global'

# Ignore bundler config.
/.bundle

# Ignore all environment files (dotenv).
/.env*
!/.env*.example

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep
!/tmp/cache/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore precompiled assets.
/public/assets
/public/packs
/public/webpack

# Ignore yarn files
/yarn-error.log
yarn-debug.log*
.yarn-integrity

# Ignore uploaded files in development
/storage

# SQLite database files
*.sqlite3
*.sqlite3-*

# PostgreSQL and MySQL dump files  
*.sql

# Redis dump files
dump.rdb

# Ignore node_modules
node_modules/

# Ignore IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Ignore coverage reports
/coverage/

# Ignore RubyMine files
.idea

# Ignore byebug history
.byebug_history

# Ignore spring files
/spring/*.pid

# Ignore bootsnap cache
/tmp/bootsnap*

# Ignore credentials
/config/credentials/*.key

# Ignore test artifacts
/test/tmp/
/test/dummy/db/*.sqlite3
/test/dummy/db/*.sqlite3-journal
/test/dummy/db/*.sqlite3-*
/test/dummy/log/*.log
/test/dummy/storage/
/test/dummy/tmp/

# Ignore system test artifacts
/tmp/capybara/*
/tmp/screenshots/
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore playwright artifacts
/.playwright-mcp/

# Ignore local development files
/config/database.yml.local
/config/secrets.yml.local
/config/environments/development.local.rb
/config/environments/test.local.rb

# Ignore backup files
*.bak
*.backup

# Ignore documentation files
/doc/
/rdoc/

# Ignore cached files
.sass-cache/
.cache/

# Ignore package-lock files (if using yarn)
package-lock.json

# Ignore local gem files
*.gem

# Ignore Vagrant files
.vagrant/

# Ignore Docker files (if not using Docker for production)
# docker-compose.override.yml

# Ignore local configuration overrides
.env.local
.env.development.local
.env.test.local
.env.production.local